# --- Vexa Environment ---
# Copy to repo root as .env:  cp deploy/env-example .env
# Then edit the REQUIRED fields below.

# ============================================================================
# RoosterX audio-only fork
# ============================================================================
# This fork records meeting audio and uploads it to object storage (R2/S3).
# Transcription, voice-agent, MCP, TTS and the dashboard are stripped/gated.
# Nothing in the REQUIRED section is mandatory for audio-only operation.

# Transcription is OFF by default. Leave these unset for audio-only. Only set
# them if you re-enable transcription (TRANSCRIPTION_ENABLED=true below) and
# self-host services/transcription-service/.
# TRANSCRIPTION_SERVICE_URL=https://transcription.vexa.ai/v1/audio/transcriptions
# TRANSCRIPTION_SERVICE_TOKEN=your-token

# ============================================================================
# Ports — change these to avoid conflicts with other stacks
# ============================================================================
API_GATEWAY_HOST_PORT=8056
ADMIN_API_PORT=8057
RUNTIME_API_PORT=8090
AGENT_API_PORT=8100
CALENDAR_SERVICE_PORT=8050
DASHBOARD_HOST_PORT=3001
POSTGRES_HOST_PORT=5458
MCP_HOST_PORT=18888
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# ============================================================================
# Defaults — work as-is for local dev
# ============================================================================

# Admin
ADMIN_TOKEN=changeme

# Image tag — pre-built from DockerHub by default.
# `make build` writes a local tag to .last-tag which overrides this.
IMAGE_TAG=latest
BROWSER_IMAGE=vexaai/vexa-bot:latest


# Database (embedded postgres by default)
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres
# For external DB, uncomment:
# REMOTE_DB=true
# DB_HOST=your-postgres-host
# DB_PORT=5432

# Storage (embedded minio by default for local dev)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_SECURE=false

# --- Cloudflare R2 (S3-compatible) for production recordings ---
# meeting-api uploads recordings via boto3. To use R2: pre-create an R2 bucket
# + API token in the Cloudflare dashboard, then set STORAGE_BACKEND=s3 (above)
# and fill these in:
# STORAGE_BACKEND=s3
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=roosterx-recordings
# S3_SECURE=true
# AWS_ACCESS_KEY_ID=<r2-access-key-id>
# AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>
# AWS_REGION=auto
# Optional — browser-reachable endpoint for presigned download URLs:
# MINIO_PUBLIC_ENDPOINT=https://<bucket>.<account-id>.r2.cloudflarestorage.com

# --- Audio-only fork toggles ---
# Transcript ingestion in meeting-api (collector tasks). false = lighter.
TRANSCRIPTION_ENABLED=false
# Default transcribe_enabled for new bots when a request omits it. false = the
# bot skips the transcription pipeline (VAD/Whisper) and just records audio.
TRANSCRIBE_DEFAULT=false

# Post-meeting webhook (optional). Default empty (agent-api hook removed).
# POST_MEETING_HOOKS=https://your-completion-webhook
